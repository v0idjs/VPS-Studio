# VPS Studio Environment Configuration
# Copy this file to .env and modify as needed

# Development
VITE_APP_TITLE="VPS Studio"

# SSH Configuration
# Default SSH port for new servers (if not specified in server config)
VITE_DEFAULT_SSH_PORT=22

# Database
# Override default database path (optional)
# VITE_DB_PATH="" 

# Application
# Window dimensions (optional)
VITE_WINDOW_WIDTH=1280
VITE_WINDOW_HEIGHT=720

# Features
# Enable/disable specific features (optional)
VITE_ENABLE_DOCKER=true
VITE_ENABLE_FIREWALL=true
